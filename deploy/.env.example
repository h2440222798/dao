# ============================
# 道家五行 - 云服务器环境配置
# 将此文件复制为 .env 并填入实际值
# ============================

# ===== 镜像配置 =====
# 阿里云 ACR 镜像地址
FRONTEND_IMAGE=crpi-bg707mmzowonrkt4.cn-beijing.personal.cr.aliyuncs.com/daojiawuxing/frontend
BACKEND_IMAGE=crpi-bg707mmzowonrkt4.cn-beijing.personal.cr.aliyuncs.com/daojiawuxing/backend
IMAGE_TAG=latest

# ===== 应用端口 =====
# 前端暴露的端口（nginx）
APP_PORT=8080

# ===== 数据库配置 =====
# 使用 Compose 内置 MySQL 服务
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/daojiawuxing?useSSL=false&serverTimezone=Asia/Shanghai&characterEncoding=utf8&connectTimeout=10000&socketTimeout=60000
SPRING_DATASOURCE_USERNAME=daojiawuxing
SPRING_DATASOURCE_PASSWORD=zhangsan@123
DB_ROOT_PASSWORD=root123456
DB_HOST=mysql
DB_PORT=3306
DB_NAME=daojiawuxing
DB_USERNAME=daojiawuxing
DB_PASSWORD=zhangsan@123

# ===== Redis 配置（可选）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
