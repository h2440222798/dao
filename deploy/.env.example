# ============================
# 道家五行 - 云服务器环境配置
# 将此文件复制为 .env 并填入实际值
# ============================

# ===== 镜像配置 =====
# 阿里云 ACR 镜像地址
FRONTEND_IMAGE=crpi-bg707mmzowonrkt4.cn-beijing.personal.cr.aliyuncs.com/daojiawuxing/frontend
BACKEND_IMAGE=crpi-bg707mmzowonrkt4.cn-beijing.personal.cr.aliyuncs.com/daojiawuxing/backend
IMAGE_TAG=latest

# ===== 应用端口 =====
# 前端暴露的端口（nginx）
APP_PORT=80

# ===== 数据库配置 =====
# 连接云服务器本地 MySQL
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=daojiawuxing
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# ===== Redis 配置（可选）=====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=1
